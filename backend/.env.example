# ===========================================
# Customer Success Digital FTE - Environment Template
# ===========================================
# Copy this file to .env and fill in your values
# All mandatory fields are marked with (REQUIRED)

# ===========================================
# Application Settings
# ===========================================
APP_NAME=Customer Success Digital FTE
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================
# Full connection URL (REQUIRED)
# For Neon: postgresql://user:pass@host/db?sslmode=require
# For local: postgresql://postgres:password@localhost:5432/cs_fte
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname?sslmode=require

# Individual connection parameters (REQUIRED)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=cs_fte
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===========================================
# Security Settings (REQUIRED)
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Gmail API OAuth 2.0 (REQUIRED)
# ===========================================
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_API_KEY=your-gmail-api-key
GMAIL_REDIRECT_URI=http://localhost:8000/webhooks/gmail/callback

# ===========================================
# AI Provider Configuration (REQUIRED)
# ===========================================
# Primary provider
OPENAI_API_KEY=your-openai-api-key
OPENAI_DAILY_TOKEN_LIMIT=100000

# Fallback 1 (REQUIRED)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DAILY_TOKEN_LIMIT=100000

# Fallback 2 (REQUIRED)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_DAILY_TOKEN_LIMIT=100000

# ===========================================
# Context7 MCP Configuration (REQUIRED)
# ===========================================
CONTEXT7_ENABLED=true
CONTEXT7_API_KEY=ctx7sk-your-context7-api-key

# ===========================================
# UltraMsg WhatsApp Configuration (REQUIRED)
# ===========================================
ULTRAMSG_INSTANCE_ID=your-instance-id
ULTRAMSG_TOKEN=your-ultramsg-token

# ===========================================
# Infrastructure
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TICKETS_CREATE=tickets.create
KAFKA_TOPIC_TICKETS_UPDATE=tickets.update
KAFKA_TOPIC_MESSAGES_SEND=messages.send
KAFKA_TOPIC_ESCALATIONS_TRIGGER=escalations.trigger

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
